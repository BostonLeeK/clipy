<Application
    x:Class="Clipy.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AccentBrush" Color="#C8FF4D" />
            <SolidColorBrush x:Key="BgBrush" Color="#0C0C12" />
            <SolidColorBrush x:Key="CardBrush" Color="#1A1A22" />
            <SolidColorBrush x:Key="BorderBrush" Color="#2A2A35" />
            <SolidColorBrush x:Key="PanelFrameBrush" Color="#3A4A28" />
            <SolidColorBrush x:Key="PanelFrameAccentBrush" Color="#66C8FF4D" />
            <SolidColorBrush x:Key="TextBrush" Color="#F0F0F5" />
            <SolidColorBrush x:Key="MutedBrush" Color="#8A8A9A" />

            <LinearGradientBrush x:Key="PanelFrameGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#88C8FF4D" Offset="0" />
                <GradientStop Color="#334A6A38" Offset="0.35" />
                <GradientStop Color="#2A2A35" Offset="0.7" />
                <GradientStop Color="#55A0C8FF" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
