<Window
    x:Class="Clipy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clipy.Controls">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid x:Name="PanelHost">
        <Border x:Name="FrameBorder" CornerRadius="22" Padding="1.5"
                BorderThickness="0" Background="{StaticResource PanelFrameGradient}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border x:Name="PanelView" CornerRadius="20.5" BorderThickness="1"
                    BorderBrush="#22FFFFFF" Background="{StaticResource BgBrush}">
            <Grid Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="0" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderBar" Grid.Row="0" Margin="0,0,0,8" PointerPressed="Header_PointerPressed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                            VerticalAlignment="Center" Background="Transparent">
                        <Image x:Name="HeaderAvatarImage" Width="32" Height="32"
                               Stretch="Uniform" IsHitTestVisible="False" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Clipy" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{StaticResource AccentBrush}" />
                            <TextBlock x:Name="StatusText" Text="Online" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="HomeBtn" Grid.Column="2" Style="{StaticResource IconButtonStyle}" Width="32" Height="32"
                            Margin="0,0,6,0" Click="Home_Click" Background="{StaticResource CardBrush}" CornerRadius="16"
                            ToolTipService.ToolTip="Головний екран">
                        <FontIcon Glyph="&#xE10F;" FontSize="14" Foreground="{StaticResource TextBrush}" />
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Width="32" Height="32"
                            Margin="0,0,6,0" Click="Settings_Click" Background="{StaticResource CardBrush}" CornerRadius="16">
                        <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{StaticResource TextBrush}" />
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource IconButtonStyle}" Width="32" Height="32"
                            Click="Collapse_Click" Background="{StaticResource CardBrush}" CornerRadius="16">
                        <FontIcon Glyph="&#xE921;" FontSize="12" Foreground="{StaticResource TextBrush}" />
                    </Button>
                </Grid>

                <TextBlock x:Name="WorkspaceText" Grid.Row="1" FontSize="10" Foreground="{StaticResource MutedBrush}"
                           Margin="2,0,0,8" TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="2" MinHeight="0">
                    <Grid x:Name="HomePanel">
                        <Grid x:Name="HomeBackdrop" IsHitTestVisible="False">
                            <Image x:Name="HomeBgGif" Stretch="Uniform" Opacity="0.38"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border x:Name="HomeBgOverlay" />
                        </Grid>

                        <Grid RowSpacing="10" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="0" />
                            </Grid.RowDefinitions>

                            <Border x:Name="GreetingCard" Grid.Row="0" CornerRadius="14"
                                    Padding="12,10" BorderThickness="1">
                                <TextBlock x:Name="GreetingText" Text="Привіт 👋 Чим допомогти сьогодні?" />
                            </Border>

                            <StackPanel x:Name="QuickActions" Grid.Row="1" Orientation="Horizontal" Spacing="6">
                                <Button x:Name="NewChatBtn" Style="{StaticResource ActionButtonStyle}" Content="Новий чат" Click="NewChat_Click"
                                        Background="{StaticResource AccentBrush}" Foreground="#0B0B0F" CornerRadius="10" Padding="12,6" />
                                <Button x:Name="OpenChatBtn" Style="{StaticResource ActionButtonStyle}" Content="Чат" Click="OpenChat_Click"
                                        Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                                        CornerRadius="10" Padding="12,6" Visibility="Collapsed" />
                                <Button x:Name="FolderBtn" Style="{StaticResource ActionButtonStyle}" Content="Папка" Click="Folder_Click"
                                        Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                                        CornerRadius="10" Padding="12,6" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="HomeHistoryTitle" Text="Недавні чати" FontSize="13"
                                               FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                    <Border x:Name="HomeHistoryEmptyCard" CornerRadius="14" Padding="16,14" BorderThickness="1">
                                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock x:Name="HomeHistoryEmptyIcon" Text="🌿" FontSize="24"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock x:Name="HomeHistoryEmptyTitle" Text="Ще немає чатів"
                                                       FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="HomeHistoryEmptyHint" Text="Напиши задачу внизу — з'явиться тут"
                                                       FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel x:Name="HomeHistoryPanel" Spacing="6" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel x:Name="ChatPanel" Spacing="8" />
                    </ScrollViewer>
                </Grid>

                <ScrollViewer x:Name="AttachScroll" Grid.Row="3" Visibility="Collapsed"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Margin="0,8,0,0">
                    <StackPanel x:Name="AttachPanel" Orientation="Horizontal" Spacing="6" />
                </ScrollViewer>

                <Grid Grid.Row="4" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AttachFileBtn" Grid.Column="0" Style="{StaticResource IconButtonStyle}" Width="40" Height="44"
                            Click="AttachFile_Click" Background="{StaticResource CardBrush}" CornerRadius="12"
                            ToolTipService.ToolTip="Додати файл / папку">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" Foreground="{StaticResource TextBrush}" />
                    </Button>
                    <Button x:Name="ScreenshotBtn" Grid.Column="1" Style="{StaticResource IconButtonStyle}" Width="40" Height="44"
                            Margin="6,0,0,0" Click="Screenshot_Click" Background="{StaticResource CardBrush}" CornerRadius="12"
                            ToolTipService.ToolTip="Скрін екрана (Ctrl+Shift+S)">
                        <FontIcon Glyph="&#xE7C5;" FontSize="14" Foreground="{StaticResource TextBrush}" />
                    </Button>
                    <Button x:Name="VoiceBtn" Grid.Column="2" Style="{StaticResource IconButtonStyle}" Width="40" Height="44"
                            Margin="6,0,0,0" Click="Voice_Click" Background="{StaticResource CardBrush}" CornerRadius="12"
                            ToolTipService.ToolTip="Голосовий ввід">
                        <FontIcon Glyph="&#xE720;" FontSize="14" Foreground="{StaticResource TextBrush}" />
                    </Button>
                    <controls:ChatInputBox x:Name="InputBox" Grid.Column="3"
                             PlaceholderText="Напиши задачу…  Ctrl+Enter — надіслати"
                             AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="80" MinHeight="44"
                             Margin="8,0,0,0" Background="#111118" Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}" CornerRadius="12"
                             Paste="Input_Paste" AllowDrop="True"
                             DragOver="Input_DragOver" Drop="Input_Drop" />
                    <Button x:Name="SendButton" Grid.Column="4" Style="{StaticResource IconButtonStyle}" Width="44" Height="44"
                            Margin="8,0,0,0" Click="Send_Click" Background="{StaticResource AccentBrush}" CornerRadius="22">
                        <FontIcon x:Name="SendIcon" Glyph="&#xE724;" FontSize="16" Foreground="#0B0B0F" />
                    </Button>
                </Grid>

                <Grid Grid.Row="5" Margin="0,6,0,0">
                    <TextBlock x:Name="FooterStatus" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="2,0,36,0"
                               VerticalAlignment="Center"
                               Text="Ctrl+Enter — надіслати · Ctrl+Shift+C — відкрити/сховати" />

                    <Border x:Name="ResizeGrip" Width="30" Height="30"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="{StaticResource CardBrush}" CornerRadius="10"
                            BorderBrush="#33FFFFFF" BorderThickness="1"
                            PointerPressed="ResizeGrip_PointerPressed"
                            PointerMoved="ResizeGrip_PointerMoved"
                            PointerReleased="ResizeGrip_PointerReleased"
                            PointerCaptureLost="ResizeGrip_PointerReleased"
                            ToolTipService.ToolTip="Потягни для зміни розміру">
                        <FontIcon x:Name="ResizeGripIcon" Glyph="&#xE73F;" FontSize="13"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Foreground="{StaticResource AccentBrush}" />
                    </Border>
                </Grid>

                <Grid x:Name="HistoryOverlay" Grid.RowSpan="6" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="HistoryHeader" Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" VerticalAlignment="Center">
                            <Image x:Name="HistoryAvatarImage" Width="32" Height="32" Stretch="Uniform" IsHitTestVisible="False" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="HistoryTitleText" Text="Історія чатів" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock x:Name="HistorySubtitleText" Text="Попередні сесії" FontSize="11" />
                        </StackPanel>
                        <Button x:Name="HistoryBackBtn" Grid.Column="2" Style="{StaticResource IconButtonStyle}"
                                Width="32" Height="32" Click="HistoryBack_Click" CornerRadius="16">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="8">
                            <Border x:Name="HistoryEmptyCard" CornerRadius="14" Padding="20,18,20,18" BorderThickness="1">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock x:Name="HistoryEmptyIcon" Text="🌿" FontSize="28" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="HistoryEmptyTitle" Text="Ще немає збережених чатів"
                                               FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" />
                                    <TextBlock x:Name="HistoryEmptyHint" Text="Почніть новий чат — він з'явиться тут"
                                               FontSize="11" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <StackPanel x:Name="HistoryPanel" Spacing="6" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="SettingsOverlay" Grid.RowSpan="6" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="SettingsHeader" Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" VerticalAlignment="Center">
                            <Image x:Name="SettingsAvatarImage" Width="32" Height="32" Stretch="Uniform" IsHitTestVisible="False" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="SettingsTitleText" Text="Налаштування" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock x:Name="SettingsSubtitleText" Text="Агент, тема, workspace" FontSize="11" />
                        </StackPanel>
                        <Button x:Name="SettingsBackBtn" Grid.Column="2" Style="{StaticResource IconButtonStyle}"
                                Width="32" Height="32" Click="SettingsBack_Click" CornerRadius="16">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SettingsCardsPanel" Spacing="10">
                            <Border x:Name="SettingsProviderCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsProviderTitle" Text="Провайдер агента" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SettingsProviderHint" FontSize="11" TextWrapping="Wrap" />
                                    <ComboBox x:Name="SettingsProviderCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="SettingsProvider_SelectionChanged" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsAuthCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsAuthTitle" Text="Cursor Agent" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SettingsAuthStatus" FontSize="12" TextWrapping="Wrap" />
                                    <Button x:Name="SettingsLoginBtn" Style="{StaticResource ActionButtonStyle}"
                                            Content="Увійти в Cursor" Click="SettingsLogin_Click"
                                            CornerRadius="10" Padding="12,8" HorizontalAlignment="Stretch" />
                                    <Button x:Name="SettingsLogoutBtn" Style="{StaticResource ActionButtonStyle}"
                                            Content="Вийти" Click="SettingsLogout_Click"
                                            CornerRadius="10" Padding="12,8" HorizontalAlignment="Stretch" Visibility="Collapsed" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsModeCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsModeTitle" Text="Режим агента" FontSize="13" FontWeight="SemiBold" />
                                    <ComboBox x:Name="SettingsModeCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="SettingsMode_SelectionChanged">
                                        <ComboBoxItem Content="Agent" Tag="agent" />
                                        <ComboBoxItem Content="Ask (лише Q&amp;A)" Tag="ask" />
                                        <ComboBoxItem Content="Plan (без правок)" Tag="plan" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsModelCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsModelTitle" Text="Модель" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SettingsModelHint" Text="Для спілкування через Cursor Agent CLI" FontSize="11" TextWrapping="Wrap" />
                                    <ComboBox x:Name="SettingsModelCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="SettingsModel_SelectionChanged" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsWorkspaceCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsWorkspaceTitle" Text="Робоча папка" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SettingsWorkspaceText" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <ComboBox x:Name="SettingsRecentWorkspaceCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="SettingsRecentWorkspace_SelectionChanged" />
                                    <Button x:Name="SettingsFolderBtn" Style="{StaticResource ActionButtonStyle}"
                                            Content="Змінити папку" Click="Folder_Click"
                                            CornerRadius="10" Padding="12,8" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsLanguageCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsLanguageTitle" Text="Мова" FontSize="13" FontWeight="SemiBold" />
                                    <ComboBox x:Name="SettingsLanguageCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="SettingsLanguage_SelectionChanged">
                                        <ComboBoxItem Content="Українська" Tag="uk" />
                                        <ComboBoxItem Content="English" Tag="en" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsThemesCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsThemesTitle" Text="Теми" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SettingsThemesHint" Text="Маскот і кольори панелі" FontSize="11" />
                                    <StackPanel x:Name="ThemesPanel" Spacing="6" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsUpdateCard" CornerRadius="14" Padding="14" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsUpdateTitle" Text="Оновлення" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SettingsVersionText" FontSize="11" />
                                    <TextBlock x:Name="SettingsUpdateStatus" FontSize="12" TextWrapping="Wrap" />
                                    <ProgressBar x:Name="SettingsUpdateProgress" Minimum="0" Maximum="1"
                                                 Visibility="Collapsed" Height="6" />
                                    <Button x:Name="SettingsCheckUpdateBtn" Style="{StaticResource ActionButtonStyle}"
                                            Content="Перевірити оновлення" Click="SettingsCheckUpdate_Click"
                                            CornerRadius="10" Padding="12,8" HorizontalAlignment="Stretch" />
                                    <Button x:Name="SettingsInstallUpdateBtn" Style="{StaticResource ActionButtonStyle}"
                                            Content="Оновити зараз" Click="SettingsInstallUpdate_Click"
                                            CornerRadius="10" Padding="12,8" HorizontalAlignment="Stretch"
                                            Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
            </Border>
        </Border>
        <Image x:Name="FrameDecorImage"
               Stretch="Fill" IsHitTestVisible="False" Visibility="Collapsed"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
